{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "box.log",
    "timestamp": false
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "access_control_allow_origin": ["http://board.zash.run.place", "http://clash.razord.top"],
      "access_control_allow_private_network": true,
      "external_ui": "ui",
      "external_ui_download_url": "https://ghfast.top/https://github.com/Zephyruso/zashboard/releases/latest/download/dist.zip",
      "external_ui_download_detour": "direct-out",
      "secret": "password"
    }
  },
  "dns": {
    "final": "dns_encrypt",
    "strategy": "ipv4_only",
    "servers": [
      {
        "type": "udp",
        "tag": "dns_udp",
        "server": "119.29.29.29"
      },
      {
        "type": "https",
        "tag": "dns_encrypt",
        "server": "doh.pub",
        "domain_resolver": "dns_udp"
      },
      {
        "type": "tls",
        "tag": "dns_remote",
        "server": "8.8.8.8",
        "detour": "select-out"
      }
    ],
    "rules": [
      {
        "action": "reject",
        "rule_set": ["reject_ads"]
      },
      {
        "action": "route",
        "server": "dns_udp",
        "rule_set": ["domestic", "in_direct"]
      },
      {
        "action": "route",
        "server": "dns_remote",
        "rule_set": ["global"]
      }
    ]
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"],
      "auto_route": true,
      "auto_redirect": true,
      "route_exclude_address_set": ["geoip_cn"],
      "stack": "gvisor",
      "endpoint_independent_nat": true
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "dns_udp",
    "final": "select-out",
    "rules": [
      {
        "action": "sniff",
        "sniffer": ["http", "tls", "quic", "dns", "bittorrent"]
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "action": "route",
        "outbound": "direct-out",
        "protocol": ["bittorrent"]
      },
      {
        "action": "route",
        "outbound": "direct-out",
        "rule_set": ["domestic", "in_direct"]
      },
      {
        "action": "route",
        "outbound": "select-out",
        "rule_set": ["global"]
      },
      {
        "action": "route",
        "outbound": "direct-out",
        "ip_is_private": true,
        "rule_set": ["geoip_cn"]
      }
    ],
    "rule_set": [
      {
        "type": "inline",
        "tag": "in_direct",
        "rules": [{ "domain_suffix": ["steamserver.net", "steamcontent.com"] }]
      },
      {
        "type": "remote",
        "tag": "reject_ads",
        "format": "binary",
        "url": "https://anti-ad.net/anti-ad-sing-box.srs",
        "download_detour": "direct-out",
        "update_interval": "6h"
      },
      {
        "type": "remote",
        "tag": "global",
        "format": "binary",
        "url": "https://ghfast.top/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "direct-out",
        "update_interval": "6h"
      },
      {
        "type": "remote",
        "tag": "domestic",
        "format": "binary",
        "url": "https://ghfast.top/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-cn.srs",
        "download_detour": "direct-out",
        "update_interval": "6h"
      },
      {
        "type": "remote",
        "tag": "geoip_cn",
        "format": "binary",
        "url": "https://ghfast.top/https://github.com/Loyalsoldier/geoip/raw/release/srs/cn.srs",
        "download_detour": "direct-out",
        "update_interval": "6h"
      }
    ]
  },
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    }
  ]
}
