{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "",
    "timestamp": false
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_direct",
        "address": "119.29.29.29",
        "detour": "direct-out"
      },
      {
        "tag": "dns_fakeip",
        "address": "fakeip"
      }
    ],
    "rules": [
      {
        "rule_set": ["process_direct", "domestic"],
        "server": "dns_direct"
      },
      {
        "rule_set": ["llm", "global"],
        "server": "dns_fakeip",
        "rewrite_ttl": 1
      }
    ],
    "fakeip": {
      "enabled": true,
      "inet4_range": "172.16.0.0/12",
      "inet6_range": "fccc::/16"
    },
    "final": "dns_direct",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "inet4_address": "192.168.100.1/30",
      "inet6_address": "fddd::1/126",
      "mtu": 9000,
      "auto_route": true,
      "sniff": true,
      "sniff_timeout": "10ms"
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7000,
      "sniff": true,
      "sniff_timeout": "10ms",
      "domain_strategy": "prefer_ipv4"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    },
    {
      "type": "block",
      "tag": "block-out"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "reject",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/anti_ad.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "process_direct",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/process_direct.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "llm",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/llm.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "global",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "domestic",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geoip_cn",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geoip/raw/rule-set/geoip-cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      }
    ],
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "rule_set": ["reject"],
        "outbound": "block-out"
      },
      {
        "rule_set": ["process_direct", "domestic"],
        "outbound": "direct-out"
      },
      {
        "rule_set": ["llm", "global"],
        "outbound": "select-out"
      },
      {
        "ip_is_private": true,
        "rule_set": ["geoip_cn"],
        "outbound": "direct-out"
      }
    ],
    "final": "select-out",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": ".cache",
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://mirror.ghproxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "direct-out",
      "secret": ""
    }
  }
}
