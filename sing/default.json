{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "",
    "timestamp": false
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_direct",
        "address": "223.5.5.5",
        "strategy": "prefer_ipv6",
        "detour": "direct-out"
      },
      {
        "tag": "dns_proxy",
        "address": "h3://223.5.5.5/dns-query",
        "strategy": "ipv4_only"
      },
      {
        "tag": "dns_block",
        "address": "rcode://refused"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "dns_direct"
      },
      {
        "clash_mode": "direct",
        "server": "dns_direct"
      },
      {
        "clash_mode": "global",
        "server": "dns_proxy"
      },
      {
        "rule_set": ["stream", "global"],
        "server": "dns_proxy"
      },
      {
        "rule_set": "reject",
        "server": "dns_block",
        "disable_cache": true
      }
    ],
    "final": "dns_direct"
  },
  "inbounds": [
    {
      "type": "tun",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fdfe:dcba:9876::1/126",
      "auto_route": true,
      "stack": "system",
      "sniff": true,
      "sniff_timeout": "5ms"
    },
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 7000,
      "sniff": true,
      "sniff_timeout": "5ms"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    },
    {
      "type": "block",
      "tag": "block-out"
    }
  ],
  "route": {
    "rules": [
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "protocol": "dns"
          },
          {
            "port": 53
          }
        ],
        "outbound": "dns-out"
      },
      {
        "rule_set": "reject",
        "outbound": "block-out"
      },
      {
        "domain_keyword": ["tracker", "m-team"],
        "outbound": "direct-out"
      },
      {
        "rule_set": ["process_cn"],
        "outbound": "direct-out"
      },
      {
        "clash_mode": "direct",
        "outbound": "direct-out"
      },
      {
        "clash_mode": "global",
        "outbound": "select-out"
      },
      {
        "rule_set": ["stream", "global"],
        "outbound": "select-out"
      },
      {
        "rule_set": ["domestic", "geoip_cn"],
        "outbound": "direct-out"
      },
      {
        "ip_is_private": true,
        "outbound": "direct-out"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "reject",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/anti_ad.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "stream",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/stream.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "global",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-!cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "domestic",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geosite/raw/rule-set/geosite-geolocation-cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "geoip_cn",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/SagerNet/sing-geoip/raw/rule-set/geoip-cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      },
      {
        "type": "remote",
        "tag": "process_cn",
        "format": "binary",
        "url": "https://mirror.ghproxy.com/https://github.com/srk24/profile/raw/master/sing/ruleset/process_cn.srs",
        "download_detour": "direct-out",
        "update_interval": "1d"
      }
    ],
    "final": "select-out",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": ".cache",
      "cache_id": "default",
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://mirror.ghproxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "select-out",
      "secret": ""
    }
  }
}
