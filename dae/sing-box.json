{
  "log": {
    "disabled": false,
    "level": "warn",
    "output": "box.log",
    "timestamp": false
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "access_control_allow_origin": ["http://yacd.haishan.me", "http://clash.razord.top"],
      "access_control_allow_private_network": true,
      "external_ui": "ui"
    }
  },
  "dns": {
    "final": "dns_encrypt",
    "strategy": "ipv4_only",
    "servers": [
      {
        "type": "https",
        "tag": "dns_encrypt",
        "server": "223.5.5.5"
      },
      {
        "type": "fakeip",
        "tag": "dns_fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "action": "route",
        "server": "dns_fakeip",
        "inbound": "dns-in",
        "strategy": "ipv4_only",
        "rewrite_ttl": 1
      }
    ]
  },
  "inbounds": [
    {
      "type": "direct",
      "tag": "dns-in",
      "network": "udp",
      "listen": "0.0.0.0",
      "listen_port": 5353
    },
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "listen_port": 7000
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "dns_encrypt",
    "final": "direct-out",
    "rules": [
      {
        "action": "sniff",
        "sniffer": ["http", "tls", "quic", "dns"]
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "action": "route",
        "inbound": "socks-in",
        "outbound": "select-out"
      }
    ]
  },
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct-out"
    }
  ]
}
