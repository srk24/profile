global {
  tproxy_port: 7000
  tproxy_port_protect: true
  log_level: info
  disable_waiting_network: false
  lan_interface: br-lan
  wan_interface: auto
  auto_config_kernel_parameter: true
  tcp_check_url: 'http://cp.cloudflare.com,1.1.1.1,2606:4700:4700::1111'
  tcp_check_http_method: HEAD
  udp_check_dns: 'dns.google.com:53,8.8.8.8,2001:4860:4860::8888'
  check_interval: 30s
  check_tolerance: 0ms
  dial_mode: domain
  allow_insecure: false
  sniffing_timeout: 100ms
  tls_implementation: tls
  utls_imitate: chrome_auto
  enable_local_tcp_fast_redirect: true
  auto_config_kernel_parameter: true
}

# https://github.com/daeuniverse/dae/blob/main/docs/en/configuration/dns.md
dns {
  ipversion_prefer: 4
  upstream {
    udpdns: 'udp://119.29.29.29:53'
    encryptdns: 'https://1.12.12.12/dns-query'
  }
  routing {
    request {
      qname(geosite:category-ads-all) -> reject
      qname(geosite:cn) -> udpdns
      qname(geosite:geolocation-!cn) -> encryptdns
      fallback: encryptdns
    }
  }
}

# https://github.com/daeuniverse/dae/blob/main/docs/en/configuration/routing.md
routing {
  pname(NetworkManager, systemd-resolved, dnsmasq, mosdns) -> must_direct
  dscp(0x4) -> direct # https://github.com/daeuniverse/dae/discussions/295
  domain(geosite:geolocation-!cn) -> proxy
  dip(geoip:cn) -> direct
  dip(geoip:private) -> direct
  domain(geosite:cn) -> direct
  fallback: proxy
}

subscription {
  sub_one: 'https://'
}

group {
  proxy {
    filter: subtag(sub_one) && name(regex: '.*')
    policy: min_moving_avg
  }
}